<% layout("/layouts/boilerplate")  %>
<% let searchValue = typeof search !== 'undefined' ? search : '' %>
<% let activeCategory = typeof category !== 'undefined' ? category : '' %>
<style>
.filters-main {
    display: flex;
    align-items: center;
    width: 100%;
}
#filters{
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    flex-grow: 1;
}
.filter{
    text-align: center;
    margin-right: 2rem;
    margin-top: 2rem;
    opacity: 0.5;
    transition: all 0.2s ease;
    text-decoration: none;
    color: #222;
}
.filter:hover {
    opacity: 1;
    cursor: pointer;
    transform: translateY(-2px);
}
.filter.active {
    opacity: 1;
    border-bottom: 2px solid #222;
    padding-bottom: 0.3rem;
}
.filter p {
    font-size: 0.8rem;
    margin-bottom: 0;
    margin-top: 0.4rem;
    white-space: nowrap;
}
.filter i {
    font-size: 1.4rem;
}
.tax-info{
    display: none;
}
.tax-toggle{
    border: 1px solid #ddd;
    border-radius: 1rem;
    height: 3.2rem;
    padding: 0.7rem 1rem;
    margin-left: 1rem;
    display: flex;
    align-items: center;
    white-space: nowrap;
    flex: 0 0 auto;
    margin-top: 1rem;
}

@media (max-width: 991px) {
    .filter{
        margin-right: 1.5rem;
        margin-top: 1.5rem;
    }
    .filter i {
        font-size: 1.2rem;
    }
    .filter p {
        font-size: 0.75rem;
    }
}

@media (max-width: 767px) {
    .filters-main {
        flex-direction: column;
        align-items: stretch;
    }
    #filters {
        flex-wrap: nowrap;
        overflow-x: auto;
        /* Hide scrollbar for cleaner look */
        -ms-overflow-style: none;  /* IE and Edge */
        scrollbar-width: none;  /* Firefox */
        padding-bottom: 0.5rem;
        width: 100%;
    }
    #filters::-webkit-scrollbar {
        display: none; /* Chrome, Safari and Opera */
    }
    .filter {
        flex: 0 0 auto;
        margin-right: 1.2rem;
        margin-top: 1rem;
    }
    .filter i {
        font-size: 1.1rem;
    }
    .filter p {
        font-size: 0.7rem;
    }
    .tax-toggle {
        margin-left: 0;
        margin-top: 0.5rem;
        width: fit-content;
        align-self: center;
    }
}

@media (max-width: 575px) {
    .filter {
        margin-right: 1rem;
        margin-top: 1rem;
    }
    .filter i {
        font-size: 1rem;
    }
    .filter p {
        font-size: 0.65rem;
    }
}
</style>
  

    <div class="filters-main">
        <div id="filters">
            <a href="/listings?category=Trending" class="filter <%= activeCategory === 'Trending' ? 'active' : '' %>">
                <div><i class="fa-solid fa-fire"></i></div>
                <p>Trending</p>
            </a>
            <a href="/listings?category=Rooms" class="filter <%= activeCategory === 'Rooms' ? 'active' : '' %>">
                <div><i class="fa-solid fa-bed"></i></div>
                <p>Rooms</p>
            </a>
            <a href="/listings?category=Mountains" class="filter <%= activeCategory === 'Mountains' ? 'active' : '' %>">
                <div><i class="fa-solid fa-mountain"></i></div>
                <p>Mountains</p>
            </a>
            <a href="/listings?category=Iconic Cities" class="filter <%= activeCategory === 'Iconic Cities' ? 'active' : '' %>">
                <div><i class="fa-solid fa-city"></i></div>
                <p>Iconic Cities</p>
            </a>
            <a href="/listings?category=Castles" class="filter <%= activeCategory === 'Castles' ? 'active' : '' %>">
                <div><i class="fa-brands fa-fort-awesome"></i></div>
                <p>Castles</p>
            </a>
            <a href="/listings?category=Amazing pools" class="filter <%= activeCategory === 'Amazing pools' ? 'active' : '' %>">
                <div><i class="fa-solid fa-person-swimming"></i></div>
                <p>Amazing pools</p>
            </a>
            <a href="/listings?category=Camping" class="filter <%= activeCategory === 'Camping' ? 'active' : '' %>">
                <div><i class="fa-solid fa-tent"></i></div>
                <p>Camping</p>
            </a>
            <a href="/listings?category=Farms" class="filter <%= activeCategory === 'Farms' ? 'active' : '' %>">
                <div><i class="fa-solid fa-cow"></i></div>
                <p>Farms</p>
            </a>
            <a href="/listings?category=Arctic" class="filter <%= activeCategory === 'Arctic' ? 'active' : '' %>">
                <div><i class="fa-solid fa-snowflake"></i></div>
                <p>Arctic</p>
            </a>
            <a href="/listings?category=Domes" class="filter <%= activeCategory === 'Domes' ? 'active' : '' %>">
                <div><i class="fa-solid fa-landmark-dome"></i></div>
                <p>Domes</p>
            </a>
            <a href="/listings?category=Boats" class="filter <%= activeCategory === 'Boats' ? 'active' : '' %>">
                <div><i class="fa-solid fa-sailboat"></i></div>
                <p>Boats</p>
            </a>
        </div>
        <div class="tax-toggle">
            <div class="form-check-reverse form-switch">
             <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
             <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
            </div>
        </div>
    </div>


<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
    <% if (allListings.length === 0) { %>
        <div class="col-12 text-center" style="margin: 3rem 0;">
            <i class="fa-solid fa-magnifying-glass" style="font-size: 2.5rem; color: #ccc; margin-bottom: 1rem;"></i>
            <h4 style="color: #717171;">No listings found<% if (activeCategory) { %> in "<%= activeCategory %>"<% } %></h4>
            <p style="color: #999;">Try a different category or <a href="/listings" style="color: #fe424d;">view all listings</a></p>
        </div>
    <% } else { %>
        <% for(let listing of allListings){%>
        <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="card col listing-card" >
            <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 20rem;">
            <div class="card-img-overlay"></div>
            <div class="card-body">
                <p class="card-text">
                    <b><%= listing.title %> <br /></b>
                    &#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %> / night
                    <i class="tax-info"> &nbsp; &nbsp;+18% GST</i>
                </p>
            </div>
        </div>
        </a>
        <% } %>
    <% } %>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        let taxSwitch = document.getElementById("switchCheckDefault");
        if (taxSwitch) {
            taxSwitch.addEventListener("click", () => {
                let taxInfo = document.getElementsByClassName("tax-info");
                for (let info of taxInfo) {
                    if (info.style.display !== "inline") {
                        info.style.display = "inline";
                    } else {
                        info.style.display = "none";
                    }
                }
            });
        }
    });
</script>
